# Anthropic — required
ANTHROPIC_API_KEY=sk-ant-...

# MCP server (FastMCP over HTTP)
MCP_URL=http://localhost:7700/mcp/

# State (SQLite; WAL mode enabled at runtime)
STATE_DB_PATH=./hermes_state.db

# Model + planner tuning
PLANNER_MODEL=claude-sonnet-4-6
WORKER_MODEL=claude-sonnet-4-6
PLANNER_EFFORT=high
PLANNER_THINKING=adaptive

# Routing thresholds
BULK_DOC_THRESHOLD=20

# Sandbox limits
SANDBOX_TIMEOUT_SECONDS=120
SANDBOX_RSS_MB=512

# API
API_HOST=0.0.0.0
API_PORT=8080
