FROM python:3.11-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /srv

COPY pyproject.toml ./
RUN pip install --upgrade pip && pip install \
    "anthropic>=0.45.0" \
    "fastapi>=0.115.0" \
    "uvicorn[standard]>=0.30.0" \
    "fastmcp>=0.4.0" \
    "mcp>=1.0.0" \
    "httpx>=0.27.0" \
    "pydantic>=2.7.0" \
    "pydantic-settings>=2.4.0" \
    "aiosqlite>=0.20.0" \
    "sse-starlette>=2.1.0" \
    "loguru>=0.7.0" \
    "python-dotenv>=1.0.1"

COPY app ./app

EXPOSE 8080
CMD ["python", "-m", "app.main"]
